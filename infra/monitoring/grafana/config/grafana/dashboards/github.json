{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "GitHub Org 활동 메트릭 (ADR-010 Phase A — 웹훅 기반 무상태 지표). PR/Issue rate, time to close, PR 크기 분포. webhook(secret+이벤트 구독)이 설정되고 이벤트가 들어오기 전에는 No data 로 보인다. review coverage·first review·open/stale 는 Phase B(상태 테이블)에서 추가 예정.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["umc-product", "github"],
  "templating": {
    "list": [
      {
        "name": "repo",
        "label": "repo",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(github_pull_request_total, repo)",
        "query": {
          "qryType": 1,
          "query": "label_values(github_pull_request_total, repo)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "UMC PRODUCT — GitHub Activity",
  "uid": "umc-product-github",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PRs opened (range)",
      "description": "선택 기간 동안 열린 PR 수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(github_pull_request_total{action=\"opened\", repo=~\"$repo\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PRs merged (range)",
      "description": "선택 기간 동안 머지된 PR 수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(github_pull_request_total{action=\"merged\", repo=~\"$repo\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Issues opened (range)",
      "description": "선택 기간 동안 생성된 이슈 수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(github_issue_total{action=\"opened\", repo=~\"$repo\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Issues closed (range)",
      "description": "선택 기간 동안 종료된 이슈 수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(github_issue_total{action=\"closed\", repo=~\"$repo\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PR activity rate (by action)",
      "description": "action(opened/merged/closed/reopened)별 PR 발생 속도.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "legendFormat": "{{action}}",
          "expr": "sum by (action) (rate(github_pull_request_total{repo=~\"$repo\"}[$__rate_interval]))",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Issue activity rate (by action)",
      "description": "action(opened/closed/reopened)별 이슈 발생 속도.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "legendFormat": "{{action}}",
          "expr": "sum by (action) (rate(github_issue_total{repo=~\"$repo\"}[$__rate_interval]))",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "PR time to close (merged) — P50 / P95",
      "description": "머지된 PR 의 생성→머지 소요 시간 분위수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(github_pr_time_to_close_seconds_bucket{result=\"merged\", repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        },
        {
          "refId": "B",
          "editorMode": "code",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(github_pr_time_to_close_seconds_bucket{result=\"merged\", repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Issue time to close — P50 / P95",
      "description": "이슈 생성→종료 소요 시간 분위수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(github_issue_time_to_close_seconds_bucket{repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        },
        {
          "refId": "B",
          "editorMode": "code",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(github_issue_time_to_close_seconds_bucket{repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "PR size — changed lines (P50 / P95)",
      "description": "PR 변경 라인 수(additions+deletions) 분위수. 큰 PR 은 리뷰 지연·버그 위험의 선행지표.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "legendFormat": "p50 lines",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(github_pr_size_lines_bucket{repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        },
        {
          "refId": "B",
          "editorMode": "code",
          "legendFormat": "p95 lines",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(github_pr_size_lines_bucket{repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "PR size — changed files (P50 / P95)",
      "description": "PR 변경 파일 수 분위수.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "legendFormat": "p50 files",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(github_pr_changed_files_bucket{repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        },
        {
          "refId": "B",
          "editorMode": "code",
          "legendFormat": "p95 files",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(github_pr_changed_files_bucket{repo=~\"$repo\"}[$__rate_interval])))",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
