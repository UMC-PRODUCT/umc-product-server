# ==================================================================
# UMC PRODUCT API Server 환경변수 예시
# - 실제 비밀값은 커밋하지 말고 배포 환경 또는 로컬 .env 에만 설정한다.
# - 기본값이 application.yml 에 정의된 항목은 동일한 기본값을 기재했다.
# ==================================================================

# ------------------------------------------------------------------
# Application / Profile
# ------------------------------------------------------------------
SPRING_APPLICATION_NAME=x-umc-product
SPRING_PROFILES_ACTIVE=local
APP_ENVIRONMENT=local

# 로컬 개발자/인스턴스 식별자. 미설정 시 USER/USERNAME/HOSTNAME fallback 사용.
LOCAL_DEVELOPER_ID=
# HOSTNAME=
# USER=
# USERNAME=

# ------------------------------------------------------------------
# Server / Tomcat
# ------------------------------------------------------------------
SERVER_PORT=8080
MANAGEMENT_PORT=9090
TOMCAT_MAX_THREADS=200
TOMCAT_MIN_SPARE_THREADS=10
TOMCAT_MAX_CONNECTIONS=8192
TOMCAT_ACCEPT_COUNT=100

# ------------------------------------------------------------------
# Database / Connection Pool / Flyway
# ------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:54321/umc_product
DATABASE_USERNAME=umc_product
DATABASE_PASSWORD=umc_product_password

HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=10

FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_OUT_OF_ORDER=false

# ------------------------------------------------------------------
# Mail
# ------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=

# ------------------------------------------------------------------
# JWT / Token
# ------------------------------------------------------------------
JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
JWT_OAUTH_VERIFICATION_TOKEN_SECRET=
JWT_EMAIL_VERIFICATION_TOKEN_SECRET=
JWT_ACCESS_TOKEN_VALIDITY_IN_SECONDS=3600
JWT_REFRESH_TOKEN_VALIDITY_IN_SECONDS=604800
JWT_VERIFICATION_TOKEN_VALIDITY_IN_SECONDS=600

# ------------------------------------------------------------------
# Swagger / API Docs
# ------------------------------------------------------------------
SWAGGER_ENABLE=false
SWAGGER_ENABLE_ACTUATOR=false
SWAGGER_AUTH_USERNAME=username
SWAGGER_AUTH_PASSWORD=password

# ------------------------------------------------------------------
# Logging / Metrics / Tracing
# ------------------------------------------------------------------
LOGGING_APP_LEVEL=INFO
TRACE_SAMPLING_PROBABILITY=1.0

OTEL_URL=http://localhost:4318
OTEL_AUTH_HEADER=
OTEL_LOGS_URL=http://localhost:4318/v1/logs
OTEL_LOGS_AUTH_HEADER=
TEMPO_URL=http://localhost:4318/v1/traces
TEMPO_AUTH_HEADER=
PROM_URL=http://localhost:4318/v1/metrics
PROM_AUTH_HEADER=

# ------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------
CORS_ALLOWED_ORIGIN_PATTERNS=

# ------------------------------------------------------------------
# Notification / FCM
# ------------------------------------------------------------------
FCM_ENABLED=false
FCM_OUTBOX_INTERVAL_MS=60000
FIREBASE_CONFIGURATION=

# ------------------------------------------------------------------
# Event Outbox
# ------------------------------------------------------------------
EVENT_OUTBOX_ENABLED=false
EVENT_OUTBOX_POLL_INTERVAL_MS=5000
EVENT_OUTBOX_BATCH_SIZE=100
EVENT_OUTBOX_MAX_ATTEMPTS=5

# ------------------------------------------------------------------
# Webhook
# ------------------------------------------------------------------
WEBHOOK_BUFFER_ENABLED=true
WEBHOOK_BUFFER_FLUSH_INTERVAL_MS=60000
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ------------------------------------------------------------------
# Seed API
# ------------------------------------------------------------------
APP_SEED_ENABLED=false
APP_SEED_SKIP_THRESHOLD=0
APP_SEED_EMAIL_DOMAIN=test.umc.it.kr
APP_SEED_DEFAULT_PASSWORD=password12!

# ------------------------------------------------------------------
# OAuth2 / Social Login
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID_LIST=

APPLE_IOS_CLIENT_ID=
APPLE_WEB_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_ADMIN_KEY=
KAKAO_ALLOWED_REDIRECT_URIS=

# ------------------------------------------------------------------
# LLM / Spring AI
# LLM_PROVIDER: mock, openai, vertexai-gemini, google-genai
# ------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.0
LLM_MAX_OUTPUT_TOKENS=32
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BACKOFF_MILLIS=200
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
LLM_CIRCUIT_BREAKER_OPEN_DURATION_MILLIS=60000
LLM_RATE_LIMIT_RPM=10
LLM_RATE_LIMIT_BURST=5

# OpenAI / LM Studio / Ollama
OPENAI_BASE_URL=https://api.openai.com
LLM_OPENAI_API_KEY=

# Vertex AI / Google GenAI
VERTEX_PROJECT_ID=
VERTEX_LOCATION=asia-northeast3
GOOGLE_APPLICATION_CREDENTIALS=
LLM_GEMINI_API_KEY=
LLM_GOOGLE_GENAI_VERTEX_AI=false

# ------------------------------------------------------------------
# Figma Integration
# ------------------------------------------------------------------
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
FIGMA_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/admin/figma/oauth/callback
FIGMA_OAUTH_SCOPE=
FIGMA_TOKEN_ENCRYPTION_KEY=

FIGMA_SYNC_ENABLED=false
FIGMA_SYNC_POLL_INTERVAL=PT5M
FIGMA_SYNC_MAX_FILES_PER_RUN=50

FIGMA_DISPATCH_RETENTION=P90D
FIGMA_RETENTION_POLL_INTERVAL=PT24H
FIGMA_CLASSIFIER_CACHE_MAX_SIZE=10000
FIGMA_CLASSIFIER_CACHE_TTL=PT5M

# ------------------------------------------------------------------
# Storage
# STORAGE_PROVIDER: s3 또는 gcs
# ------------------------------------------------------------------
STORAGE_PROVIDER=s3

# S3 / CloudFront
S3_BUCKET_NAME=
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_ENABLED=false
AWS_CLOUDFRONT_DISTRIBUTION_DOMAIN=cdn.umc.it.kr
CDN_KEY_PAIR_ID=

SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
EMAIL_NO_REPLY_ADDRESS=
EMAIL_NO_REPLY_DISPLAY_NAME=

# GCS / CDN
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_CREDENTIALS_JSON=
CDN_KEY_NAME=
CDN_PRIVATE_KEY=
